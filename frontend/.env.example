# API URL — backend Express server
NEXT_PUBLIC_API_URL=http://localhost:4000

# JWT Access Secret — must match apps/api JWT_ACCESS_SECRET
# Used in Next.js middleware for Edge-compatible JWT verification
JWT_ACCESS_SECRET=your-access-secret-min-32-characters-here

# Unsplash API Key — for hero images
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Sentry — get DSN from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_DEV_OTP=true
