generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OpportunityStatus {
  ACTIVE
  CLOSED
  DRAFT
}

enum OpportunityCategory {
  EDUCATION
  HEALTH
  ENVIRONMENT
  COMMUNITY
  ARTS
  SPORTS
  TECHNOLOGY
  OTHER
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EventStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum LessonType {
  TEXT
  VIDEO
  PDF
}

enum CourseCategory {
  GENERAL
  ORIENTATION
  SAFETY
  LEADERSHIP
  SKILLS
  OTHER
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum AuditLogAction {
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  USER_SUSPEND
  USER_CHANGE_ROLE
  OPPORTUNITY_CREATE
  OPPORTUNITY_UPDATE
  OPPORTUNITY_DELETE
  EVENT_CREATE
  EVENT_UPDATE
  EVENT_DELETE
  APPLICATION_CREATE
  APPLICATION_UPDATE
  APPLICATION_DELETE
  LOGIN
  LOGOUT
  SYSTEM
  STORY_CREATE
  STORY_UPDATE
  STORY_DELETE
  STORY_PUBLISH
  STORY_UNPUBLISH
  COURSE_CREATE
  COURSE_UPDATE
  COURSE_DELETE
  LESSON_CREATE
  LESSON_UPDATE
  LESSON_DELETE
}

enum NotificationPreferenceType {
  APPLICATION_ACCEPTED
  EVENT_REMINDER
  PROMOTION
  WEEKLY_DIGEST
  SYSTEM_ANNOUNCEMENT
}

enum VolunteerType {
  STUDENT
  PROFESSIONAL
  EVENT
  RECURRING
  REMOTE
  EMERGENCY
}

enum OrganizationStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

// ─── Permission System ──────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String[]

  users User[]

  @@index([name])
}

// ─── Organization ────────────────────────────────────────────────

model Organization {
  id          String            @id @default(cuid())
  name        String
  description String?
  address     String?
  phone       String?
  email       String?
  logo        String?
  website     String?
  socialMedia Json?
  status      OrganizationStatus @default(PENDING)
  verifiedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  documents     OrganizationDocument[]
  users         User[]
  opportunities Opportunity[]

  @@index([status])
  @@index([name])
}

model OrganizationDocument {
  id             String   @id @default(cuid())
  organizationId String
  fileName       String
  fileUrl        String
  type           String   // REGISTRATION_CERTIFICATE, GOVT_ID, etc.
  uploadedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ─── Models ──────────────────────────────────────────────────────

model User {
  id         String        @id @default(cuid())
  email      String?       @unique
  name       String
  roleId     String
  roleRef    Role           @relation(fields: [roleId], references: [id])
  status     UserStatus    @default(PENDING)
  locationId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // Organization
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Volunteer type
  volunteerType VolunteerType?

  // Future gamification
  badges String[] @default([])
  points Int      @default(0)
  level  String?

  location      Location?         @relation(fields: [locationId], references: [id])
  profile       VolunteerProfile?
  refreshTokens RefreshToken[]
  consent       ConsentRecord?
  staffProfile  StaffProfile?

  createdOpportunities Opportunity[] @relation("CreatedOpportunities")
  applications         Application[] @relation("VolunteerApplications")
  attendances          Attendance[]  @relation("VolunteerAttendances")
  courseProgress       CourseProgress[]
  lessonCompletions    LessonCompletion[]
  pushSubscriptions    PushSubscription[]
  notifications        Notification[]
  stories              Story[]
  feedbackSubmissions  EventFeedback[] @relation("VolunteerFeedback")
  auditLogs            AuditLog[] @relation("AuditLogAuthor")
  notificationPrefs    NotificationPreference[]
  alertSubscriptions   AlertSubscription[]

  @@index([roleId])
  @@index([status])
  @@index([locationId])
  @@index([organizationId])
  @@index([volunteerType])
}

model VolunteerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  skills       String[]
  interests    String[]
  availability Json
  bio          String?
  avatarUrl    String?
  totalHours   Float    @default(0)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StaffProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  department  String?
  designation String?
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Location {
  id       String  @id @default(cuid())
  name     String
  district String?
  state    String?
  lat      Float?
  lng      Float?

  users         User[]
  opportunities Opportunity[]

  @@index([name])
}

model OtpRecord {
  id        String   @id @default(cuid())
  email     String
  otpHash   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ConsentRecord {
  id                    String   @id @default(cuid())
  userId                String   @unique
  privacyPolicyAccepted Boolean
  mediaConsentAccepted  Boolean
  acceptedAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Phase 2 Models ───────────────────────────────────────────────

model Opportunity {
  id              String              @id @default(cuid())
  title           String
  description     String
  skills          String[]
  category        OpportunityCategory
  locationId      String?
  createdById     String
  status          OpportunityStatus   @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime
  hoursPerSession Float
  totalSlots      Int
  isRemote        Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Organization (optional — independent opportunities have no org)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  location     Location?     @relation(fields: [locationId], references: [id])
  createdBy    User          @relation("CreatedOpportunities", fields: [createdById], references: [id])
  applications Application[]
  events       Event[]

  @@index([status])
  @@index([category])
  @@index([createdById])
  @@index([startDate])
  @@index([locationId])
  @@index([organizationId])
}

model Application {
  id            String            @id @default(cuid())
  opportunityId String
  volunteerId   String
  status        ApplicationStatus @default(PENDING)
  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  opportunity Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  volunteer   User         @relation("VolunteerApplications", fields: [volunteerId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@unique([opportunityId, volunteerId])
  @@index([volunteerId])
  @@index([status])
  @@index([opportunityId])
}

model Event {
  id            String      @id @default(cuid())
  opportunityId String
  title         String
  description   String?
  eventDate     DateTime
  startTime     String
  endTime       String
  venue         String?
  capacity      Int
  isVirtual     Boolean     @default(false)
  meetingLink   String?
  status        EventStatus @default(SCHEDULED)
  qrToken       String?     @unique
  qrExpiresAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  opportunity Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  feedback    EventFeedback[]

  @@index([opportunityId])
  @@index([eventDate])
  @@index([status])
}

model Attendance {
  id            String    @id @default(cuid())
  eventId       String
  volunteerId   String
  applicationId String
  attended      Boolean   @default(false)
  checkedInAt   DateTime?
  checkedOutAt  DateTime?
  checkInLat    Float?
  checkInLng    Float?
  checkOutLat   Float?
  checkOutLng   Float?
  markedAt      DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteer   User        @relation("VolunteerAttendances", fields: [volunteerId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([eventId, volunteerId])
  @@index([volunteerId])
  @@index([eventId])
}

// ─── Training Models ──────────────────────────────────────────────

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  category    CourseCategory
  isRequired  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons   Lesson[]
  progress  CourseProgress[]

  @@index([category])
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  content     String
  type        LessonType @default(TEXT)
  mediaUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completions LessonCompletion[]

  @@index([courseId])
}

model CourseProgress {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  completed   Boolean  @default(false)
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

// ─── Push Notifications ────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType @default(INFO)
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model EventFeedback {
  id              String   @id @default(cuid())
  eventId         String
  volunteerId     String
  rating          Int      // 1-5
  comments        String?
  learnings       String?
  confidenceLevel Int?
  createdAt       DateTime @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteer User  @relation("VolunteerFeedback", fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([eventId, volunteerId])
  @@index([eventId])
  @@index([volunteerId])
}

model Story {
  id        String   @id @default(cuid())
  title     String
  content   String
  userId    String
  mediaUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([published])
  @@index([createdAt])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    AuditLogAction
  targetId  String?  // the ID of the resource being acted on
  targetType String? // 'User', 'Opportunity', 'Event', etc.
  metadata  Json?    // arbitrary extra data
  createdAt DateTime @default(now())

  user User @relation("AuditLogAuthor", fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String
  type   NotificationPreferenceType
  email  Boolean @default(true)
  push   Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model AlertSubscription {
  id         String   @id @default(cuid())
  userId     String
  categories String[] // opportunity categories to watch
  skills     String[] // skills to watch
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([isActive, categories])
}
