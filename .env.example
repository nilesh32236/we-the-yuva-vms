# Server
NODE_ENV=development
PORT=4000

# Database — Local PostgreSQL
# Install: sudo pacman -S postgresql
# Setup:   sudo -u postgres psql -c "CREATE USER vms_user WITH PASSWORD 'vms_password';"
#          sudo -u postgres psql -c "CREATE DATABASE vms_dev OWNER vms_user;"
DATABASE_URL=postgresql://vms_user:vms_password@localhost:5432/vms_dev?connection_limit=5&pool_timeout=10

# Redis — Local Valkey/Redis (runs on port 6379 by default)
# Check: redis-cli ping  →  should return PONG
REDIS_URL=redis://127.0.0.1:6379

# JWT — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars-long!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP Email — Gmail (use App Password from myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=smtp@example.com
SMTP_PASS=smtp-password
SMTP_FROM=smtp@example.com

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=change-me-in-production-public-key
VAPID_PRIVATE_KEY=change-me-in-production-private-key

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# Resend (transactional email, optional — falls back to SMTP)
# Get API key from https://resend.com
RESEND_API_KEY=

# Sentry — get DSN from https://sentry.io
SENTRY_DSN=
